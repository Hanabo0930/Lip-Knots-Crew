rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function role() {
      return signedIn() ? request.auth.token.role : null;
    }
    function companyId() {
      return signedIn() ? request.auth.token.companyId : null;
    }
    function staffId() {
      return signedIn() ? request.auth.token.staffId : null;
    }
    function sameCompany(resourceCompanyId) {
      return signedIn() && companyId() == resourceCompanyId;
    }
    function isAdmin() {
      return role() == 'admin';
    }
    function isStaff() {
      return role() == 'staff';
    }
    function activeIdentity() {
      return !exists(/databases/$(database)/documents/authIdentities/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/authIdentities/$(request.auth.uid)).data.active == true;
    }
    function activeStaff() {
      return isStaff() &&
        exists(/databases/$(database)/documents/staffProfiles/$(staffId())) &&
        get(/databases/$(database)/documents/staffProfiles/$(staffId())).data.active == true &&
        activeIdentity();
    }
    function emergencyUnlocked() {
      return !signedIn() ||
        !exists(/databases/$(database)/documents/productionControls/$(companyId())) ||
        get(/databases/$(database)/documents/productionControls/$(companyId())).data.emergencyLock != true;
    }

    match /companies/{company}/public/{document=**} {
      allow read: if signedIn() && companyId() == company;
      allow write: if false;
    }

    match /staffProfiles/{profileId} {
      allow read: if signedIn() &&
        sameCompany(resource.data.companyId) &&
        (isAdmin() || (activeStaff() && staffId() == profileId));
      allow write: if false;
    }

    match /jobs/{jobId} {
      allow read: if signedIn() &&
        sameCompany(resource.data.companyId) &&
        (
          isAdmin() ||
          (activeStaff() && (
            resource.data.status == 'open' ||
            resource.data.assignedStaffId == staffId()
          ))
        );
      allow write: if false;
    }

    match /tasks/{taskId} {
      allow read: if signedIn() &&
        sameCompany(resource.data.companyId) &&
        (isAdmin() || (activeStaff() && resource.data.staffId == staffId()));
      allow write: if false;
    }

    match /submissions/{submissionId} {
      allow read: if signedIn() &&
        sameCompany(resource.data.companyId) &&
        (isAdmin() || (activeStaff() && resource.data.staffId == staffId()));
      allow write: if false;

      match /files/{fileId} {
        allow read: if signedIn() &&
          sameCompany(resource.data.companyId) &&
          (isAdmin() || (activeStaff() && resource.data.staffId == staffId()));
        allow write: if false;
      }
    }

    match /announcements/{announcementId} {
      allow read: if signedIn() &&
        sameCompany(resource.data.companyId) &&
        (
          isAdmin() ||
          (activeStaff() && (
            resource.data.targetAll == true ||
            staffId() in resource.data.targetStaffIds
          ))
        );
      allow write: if false;
    }

    match /deviceTokens/{uid}/tokens/{tokenId} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update, delete: if signedIn() && request.auth.uid == uid && emergencyUnlocked();
    }


    match /sheetImportConfigs/{configId} {
      allow read: if signedIn() && isAdmin() && companyId() == configId;
      allow write: if false;
    }

    match /sheetImportRuns/{runId} {
      allow read: if signedIn() && isAdmin() &&
        sameCompany(resource.data.companyId);
      allow write: if false;
    }


    match /staffImportConfigs/{configId} {
      allow read: if signedIn() && isAdmin() && companyId() == configId;
      allow write: if false;
    }

    match /staffImportRuns/{runId} {
      allow read: if signedIn() && isAdmin() &&
        sameCompany(resource.data.companyId);
      allow write: if false;
    }


    match /deviceSessions/{sessionId} {
      allow read: if signedIn() && (
        (isAdmin() && sameCompany(resource.data.companyId)) ||
        (activeStaff() && resource.data.staffId == staffId())
      );
      allow write: if false;
    }

    match /loginInviteBatches/{batchId} {
      allow read: if signedIn() && isAdmin() &&
        sameCompany(resource.data.companyId);
      allow write: if false;
    }

    match /loginInviteDeliveries/{deliveryId} {
      allow read: if signedIn() && isAdmin() &&
        sameCompany(resource.data.companyId);
      allow write: if false;
    }


    match /notificationSettings/{company} {
      allow read: if signedIn() && isAdmin() && companyId() == company;
      allow write: if false;
    }

    match /announcementReceipts/{receiptId} {
      allow read: if signedIn() && (
        isAdmin() || (activeStaff() && resource.data.staffId == staffId())
      );
      allow write: if false;
    }


    match /resubmissionRequests/{requestId} {
      allow read: if signedIn() && sameCompany(resource.data.companyId) &&
        (isAdmin() || (activeStaff() && resource.data.staffId == staffId()));
      allow write: if false;
    }


    match /sheetSyncQueue/{queueId} { allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId); allow write: if false; }
    match /filePreviewTokens/{tokenId} { allow read, write: if false; }

    match /expenseReviews/{jobId} {
      allow read: if signedIn() && isAdmin() &&
        sameCompany(resource.data.companyId);
      allow write: if false;
    }


match /companyFeatureSettings/{company} {
  allow read: if signedIn() && isAdmin() && companyId() == company;
  allow write: if false;
}

match /jobGroups/{groupId} {
  allow read: if signedIn() && isAdmin() &&
    sameCompany(resource.data.companyId);
  allow write: if false;
}

match /exportLogs/{exportId} {
  allow read: if signedIn() && isAdmin() &&
    sameCompany(resource.data.companyId);
  allow write: if false;
}


match /sheetRowCreateQueue/{queueId} {
  allow read: if signedIn() && isAdmin() &&
    sameCompany(resource.data.companyId);
  allow write: if false;
}

match /sheetRowManualInterventions/{interventionId} {
  allow read: if signedIn() && isAdmin() &&
    sameCompany(resource.data.companyId);
  allow write: if false;
}


match /setupWizardInspections/{inspectionId} {
  allow read: if signedIn() && isAdmin() &&
    sameCompany(resource.data.companyId);
  allow write: if false;
}

match /setupWizardDrafts/{company} {
  allow read: if signedIn() && isAdmin() && companyId() == company;
  allow write: if false;
}

match /monthSheetCreationRuns/{runId} {
  allow read: if signedIn() && isAdmin() &&
    sameCompany(resource.data.companyId);
  allow write: if false;
}

match /monthSheetManualInterventions/{interventionId} {
  allow read: if signedIn() && isAdmin() &&
    sameCompany(resource.data.companyId);
  allow write: if false;
}


    match /gasAuditRuns/{auditId} {
      allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
      allow write: if false;
    }
    match /firstWriteGateRuns/{runId} {
      allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
      allow write: if false;
    }
