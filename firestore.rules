    }

    match /productionControls/{company} {
      allow read: if signedIn() && isAdmin() && companyId() == company;
      allow write: if false;
    }

    match /productionReleaseEvidence/{evidenceId} {
      allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
      allow write: if false;

      match /events/{eventId} {
        allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
        allow write: if false;
      }

      match /alerts/{alertId} {
        allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
        allow write: if false;
      }

      match /reviews/{reviewId} {
        allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
        allow write: if false;
      }

      match /responsibilityAlerts/{alertKey} {
        allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
        allow write: if false;
      }

      match /weeklyReports/{weekKey} {
        allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
        allow write: if false;

        match /recipients/{recipientId} {
          allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
          allow write: if false;
        }

      }

      match /executiveReports/{weekKey} {
        allow read: if signedIn() && isAdmin() && sameCompany(resource.data.companyId);
