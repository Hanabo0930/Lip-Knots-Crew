    }

    match /stagedRolloutControls/{company} {
      allow read: if signedIn() && isAdmin() && companyId() == company;
      allow write: if false;
    }

    match /stagedRollouts/{rolloutId} {
      allow read: if signedIn() && isAdmin() &&
        sameCompany(resource.data.companyId);
      allow write: if false;
    }

    match /stagedRolloutWaves/{waveId} {
      allow read: if signedIn() && isAdmin() &&
        sameCompany(resource.data.companyId);
      allow write: if false;
    }

    match /stagedRolloutHealthRuns/{runId} {
      allow read: if signedIn() && isAdmin() &&
