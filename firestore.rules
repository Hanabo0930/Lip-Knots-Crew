    }

    match /pilotRolloutControls/{company} {
      allow read: if signedIn() && isAdmin() && companyId() == company;
      allow write: if false;
    }

    match /pilotRollouts/{rolloutId} {
      allow read: if signedIn() && isAdmin() &&
