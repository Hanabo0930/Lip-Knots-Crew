{
  "name": "lip-knots-crew-platform",
  "version": "5.6.0",
  "private": true,
  "workspaces": [
    "apps/staff",
    "apps/admin",
    "functions"
  ],
  "scripts": {
    "build": "npm run build -w @lkc/staff && npm run build -w @lkc/admin && npm run build -w @lkc/functions",
    "build:staging": "npm run preflight:staging && npm run build:staging -w @lkc/staff && npm run build:staging -w @lkc/admin && npm run build -w @lkc/functions",
    "release:staging": "npm run build:staging && node scripts/staging-deploy-readiness.mjs",
    "test": "npm run test:release -w @lkc/functions",
    "verify": "npm run build && npm run test:bundle-size && npm run test:preview-demo && npm run test:production-setup && npm run test:production-deploy-readiness && npm run test:production-deploy-orchestration && npm run test:production-acceptance && npm run test:known-good-rollback-bundle && npm run test:production-rollback-command && npm run test:production-evidence-sync && npm run test:production-evidence-security && npm run test:staging-preflight && npm run test:staging-automation && npm run test:release-checkpoint && npm run test:staging-smoke && npm run test:production-rehearsal && npm test && npm audit --omit=dev --audit-level=high",
    "test:bundle-size": "node scripts/check-bundle-size.mjs",
    "preflight:staging": "node scripts/staging-preflight.mjs",
    "test:staging-preflight": "node scripts/staging-preflight.mjs --examples --self-test",
    "setup:staging:preview": "node scripts/setup-staging.mjs --config config/staging-setup.json",
    "setup:staging": "node scripts/setup-staging.mjs --config config/staging-setup.json --write && npm run preflight:staging",
    "setup:staging:replace": "node scripts/setup-staging.mjs --config config/staging-setup.json --write --replace && npm run preflight:staging",
    "diagnose:staging": "npm run preflight:staging && node scripts/staging-deploy-readiness.mjs",
    "test:staging-automation": "node scripts/setup-staging.mjs --config config-samples/staging-setup.example.json --examples && node scripts/test-staging-automation.mjs && node scripts/staging-deploy-readiness.mjs --examples --self-test",
    "checkpoint:staging:preview": "node scripts/create-release-checkpoint.mjs --examples --dry-run",
    "checkpoint:staging": "npm run release:staging && node scripts/create-release-checkpoint.mjs",
    "rollback:staging:verify": "node scripts/prepare-staging-rollback.mjs --verify-only",
    "rollback:staging:prepare": "node scripts/prepare-staging-rollback.mjs",
    "evidence:staging:record": "node scripts/record-deployment-result.mjs",
    "test:release-checkpoint": "node scripts/create-release-checkpoint.mjs --examples --dry-run && node scripts/test-release-checkpoint.mjs",
    "smoke:staging:preview": "node scripts/run-staging-smoke.mjs --config config-samples/staging-smoke.example.json --examples --preview",
    "smoke:staging": "node scripts/run-staging-smoke.mjs",
    "test:staging-smoke": "npm run smoke:staging:preview && node scripts/test-staging-smoke.mjs",
    "rehearsal:production:preview": "node scripts/run-production-rehearsal.mjs --config config-samples/production-rehearsal.example.json --preview",
    "test:production-rehearsal": "npm run rehearsal:production:preview && node scripts/test-production-rehearsal.mjs",
    "checksums:v5.6": "node scripts/generate-checksums.mjs FILE_CHECKSUMS_SHA256_v5.6.csv",
    "checksums:v5.6:verify": "node scripts/generate-checksums.mjs FILE_CHECKSUMS_SHA256_v5.6.csv --verify",
    "preview:demo": "node scripts/preview-demo.mjs --open",
    "test:preview-demo": "node scripts/preview-demo.mjs --self-test",
    "diagnose:production": "node scripts/production-deploy-readiness.mjs --config config/production-deploy.json",
    "setup:production:preview": "node scripts/setup-production.mjs --config config/production-setup.json",
    "setup:production": "node scripts/setup-production.mjs --config config/production-setup.json --write && npm run diagnose:production",
    "setup:production:replace": "node scripts/setup-production.mjs --config config/production-setup.json --write --replace && npm run diagnose:production",
    "test:production-setup": "node scripts/setup-production.mjs --config config-samples/production-setup.example.json --examples && node scripts/test-production-setup.mjs",
    "test:production-deploy-readiness": "node scripts/production-deploy-readiness.mjs --config config-samples/production-deploy.example.json --examples --self-test",
    "deploy:production:preview": "node scripts/deploy-production.mjs --config config-samples/production-deploy.example.json --examples",
    "deploy:production:prepare": "node scripts/deploy-production.mjs --prepare",
    "deploy:production:validate": "node scripts/deploy-production.mjs --validate-approval",
    "deploy:production": "node scripts/deploy-production.mjs --apply",
    "test:production-deploy-orchestration": "node scripts/test-production-deploy-orchestration.mjs",
    "acceptance:production:preview": "node scripts/run-production-acceptance.mjs --config config-samples/production-acceptance.example.json --examples",
    "acceptance:production": "node scripts/run-production-acceptance.mjs --run",
    "acceptance:production:recovery": "node scripts/run-production-acceptance.mjs --run --after-rollback",
    "test:production-acceptance": "node scripts/test-production-acceptance.mjs",
    "rollback:bundle:preview": "node scripts/create-known-good-rollback-bundle.mjs",
    "rollback:bundle": "node scripts/create-known-good-rollback-bundle.mjs --write",
    "test:known-good-rollback-bundle": "node scripts/test-known-good-rollback-bundle.mjs",
    "rollback:production:preview": "node scripts/production-rollback.mjs --config config-samples/production-rollback.example.json --request config-samples/production-rollback-request.example.json --examples",
    "rollback:production:prepare": "node scripts/production-rollback.mjs --prepare",
    "rollback:production:validate": "node scripts/production-rollback.mjs --validate-approval",
    "rollback:production": "node scripts/production-rollback.mjs --apply",
    "test:production-rollback-command": "node scripts/test-production-rollback-command.mjs",
    "evidence:production:preview": "node scripts/create-production-evidence-sync-package.mjs",
    "evidence:production": "node scripts/create-production-evidence-sync-package.mjs --write --replace",
    "test:production-evidence-sync": "node scripts/test-production-evidence-sync.mjs",
    "test:production-evidence-security": "node scripts/test-production-evidence-security.mjs",
    "build:staff": "npm run build -w @lkc/staff",
    "build:admin": "npm run build -w @lkc/admin",
    "build:functions": "npm run build -w @lkc/functions",
    "dev:staff": "npm run dev -w @lkc/staff",
    "dev:admin": "npm run dev -w @lkc/admin",
    "emulators": "firebase emulators:start",
    "seed": "node scripts/seed-emulator.mjs",
    "verify:case-id": "node scripts/verify-case-id.mjs"
  },
  "engines": {
    "node": "22"
  },
  "overrides": {
    "whatwg-url": "7.1.0"
  },
  "devDependencies": {}
}
